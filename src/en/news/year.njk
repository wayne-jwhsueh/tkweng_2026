---
layout: layouts/base.njk
lang: en
pagination:
  data: "collections.news_years_en"
  size: 1
  alias: yearGroup
permalink: "/en/news/{{ yearGroup.year }}/index.html"
eleventyComputed:
  title: "News {{ yearGroup.year }}"
  description: "News from {{ yearGroup.year }}"
---
{% from "components/news-cards.njk" import tabs, cards %}

<h1>News</h1>
<p class="meta">Recent updates, events, and publication notes.</p>

{% set years = collections.news_en | newsYears %}

{{ tabs(years, yearGroup.year, "/en/news/", "en") }}

<div id="news-year-panel">
  {{ cards(yearGroup.posts, "en") }}
</div>

<script src="/assets/js/news-tabs.js" defer></script>
