<header class="site-header">
  <div class="container header-inner">
    <a class="brand {% if lang == "zh" %}brand-zh{% else %}brand-en{% endif %}" href="/{{ lang or 'en' }}/">
      {% if lang == "zh" %}
      {{ site.siteNameZh }}
      {% else %}
      {{ site.siteNameEn }}
      {% endif %}
    </a>
    {% set currentUrl = page.url or '/' %}
    <nav aria-label="Main navigation" class="site-nav">
      {% if lang == "zh" %}
      {% set switchUrl = currentUrl | replace('/zh/', '/en/') %}
      {% if currentUrl == '/' %}
      {% set switchUrl = '/en/' %}
      {% endif %}
      <a href="/zh/">首頁</a>
      <a href="/zh/about/">關於</a>
      <a href="/zh/portfolio/">作品</a>
      <a href="/zh/services/">服務</a>
      <a href="/zh/media/">媒體</a>
      <div class="nav-item has-submenu">
        <a href="/zh/news/">消息</a>
        <div class="submenu" role="menu" aria-label="消息子選單">
          <a href="/zh/news/archive/" role="menuitem">消息彙整</a>
        </div>
      </div>
      <a href="/zh/contact/">聯絡</a>
      <a href="{{ switchUrl }}" class="lang-switch">EN</a>
      {% else %}
      {% set switchUrl = currentUrl | replace('/en/', '/zh/') %}
      {% if currentUrl == '/' %}
      {% set switchUrl = '/zh/' %}
      {% endif %}
      <a href="/en/">Home</a>
      <a href="/en/about/">About</a>
      <a href="/en/portfolio/">Portfolio</a>
      <a href="/en/services/">Services</a>
      <a href="/en/media/">Media</a>
      <div class="nav-item has-submenu">
        <a href="/en/news/">News</a>
        <div class="submenu" role="menu" aria-label="News submenu">
          <a href="/en/news/archive/" role="menuitem">News Archive</a>
        </div>
      </div>
      <a href="/en/contact/">Contact</a>
      <a href="{{ switchUrl }}" class="lang-switch">中文</a>
      {% endif %}
    </nav>
  </div>
</header>
