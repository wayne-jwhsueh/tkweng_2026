<header class="site-header">
  <div class="container header-inner">
    <a class="brand {% if lang == "zh" %}brand-zh{% else %}brand-en{% endif %}" href="/{{ lang or 'en' }}/">
      {% if lang == "zh" %}
      {{ site.siteNameZh }}
      {% else %}
      {{ site.siteNameEn }}
      {% endif %}
    </a>
    {% set currentUrl = page.url or '/' %}
    <nav aria-label="Main navigation" class="site-nav">
      {% if lang == "zh" %}
      {% set switchUrl = currentUrl | replace('/zh/', '/en/') %}
      {% if currentUrl == '/' %}
      {% set switchUrl = '/en/' %}
      {% endif %}
      {% if currentUrl == '/zh/portfolio/realism/' %}
      {% set switchUrl = '/en/portfolio/realism/' %}
      {% endif %}
      {% if currentUrl == '/zh/portfolio/abstract/' %}
      {% set switchUrl = '/en/portfolio/abstract/' %}
      {% endif %}
      <a href="/zh/" {% if currentUrl == '/zh/' %}class="is-active" aria-current="page"{% endif %}>首頁</a>
      <a href="/zh/about/" {% if currentUrl.startsWith('/zh/about/') %}class="is-active" aria-current="page"{% endif %}>關於</a>
      <div class="nav-item has-submenu">
        <a href="/zh/portfolio/" {% if currentUrl.startsWith('/zh/portfolio/') %}class="is-active" aria-current="page"{% endif %}>作品</a>
        <div class="submenu" role="menu" aria-label="作品子選單">
          <a href="/zh/portfolio/realism/" role="menuitem" {% if currentUrl.startsWith('/zh/portfolio/realism/') %}class="is-active" aria-current="page"{% endif %}>寫實</a>
          <a href="/zh/portfolio/abstract/" role="menuitem" {% if currentUrl.startsWith('/zh/portfolio/abstract/') %}class="is-active" aria-current="page"{% endif %}>抽象</a>
        </div>
      </div>
      <a href="/zh/services/" {% if currentUrl.startsWith('/zh/services/') %}class="is-active" aria-current="page"{% endif %}>服務</a>
      <a href="/zh/media/" {% if currentUrl.startsWith('/zh/media/') %}class="is-active" aria-current="page"{% endif %}>媒體</a>
      <a href="/zh/news/" {% if currentUrl.startsWith('/zh/news/') %}class="is-active" aria-current="page"{% endif %}>消息</a>
      <a href="/zh/contact/" {% if currentUrl.startsWith('/zh/contact/') %}class="is-active" aria-current="page"{% endif %}>聯絡</a>
      <a href="{{ switchUrl }}" class="lang-switch">EN</a>
      {% else %}
      {% set switchUrl = currentUrl | replace('/en/', '/zh/') %}
      {% if currentUrl == '/' %}
      {% set switchUrl = '/zh/' %}
      {% endif %}
      {% if currentUrl == '/en/portfolio/realism/' %}
      {% set switchUrl = '/zh/portfolio/realism/' %}
      {% endif %}
      {% if currentUrl == '/en/portfolio/abstract/' %}
      {% set switchUrl = '/zh/portfolio/abstract/' %}
      {% endif %}
      <a href="/en/" {% if currentUrl == '/en/' %}class="is-active" aria-current="page"{% endif %}>Home</a>
      <a href="/en/about/" {% if currentUrl.startsWith('/en/about/') %}class="is-active" aria-current="page"{% endif %}>About</a>
      <div class="nav-item has-submenu">
        <a href="/en/portfolio/" {% if currentUrl.startsWith('/en/portfolio/') %}class="is-active" aria-current="page"{% endif %}>Portfolio</a>
        <div class="submenu" role="menu" aria-label="Portfolio submenu">
          <a href="/en/portfolio/realism/" role="menuitem" {% if currentUrl.startsWith('/en/portfolio/realism/') %}class="is-active" aria-current="page"{% endif %}>Realism</a>
          <a href="/en/portfolio/abstract/" role="menuitem" {% if currentUrl.startsWith('/en/portfolio/abstract/') %}class="is-active" aria-current="page"{% endif %}>Abstract</a>
        </div>
      </div>
      <a href="/en/services/" {% if currentUrl.startsWith('/en/services/') %}class="is-active" aria-current="page"{% endif %}>Services</a>
      <a href="/en/media/" {% if currentUrl.startsWith('/en/media/') %}class="is-active" aria-current="page"{% endif %}>Media</a>
      <a href="/en/news/" {% if currentUrl.startsWith('/en/news/') %}class="is-active" aria-current="page"{% endif %}>News</a>
      <a href="/en/contact/" {% if currentUrl.startsWith('/en/contact/') %}class="is-active" aria-current="page"{% endif %}>Contact</a>
      <a href="{{ switchUrl }}" class="lang-switch">中文</a>
      {% endif %}
    </nav>
  </div>
</header>
