<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-block footer-brand">
      <p>
        {% if lang == "zh" %}
        &copy; {{ "now" | date("yyyy") }} {{ site.artistNameZh }}
        {% else %}
        &copy; {{ "now" | date("yyyy") }} {{ site.artistNameEn }}
        {% endif %}
      </p>
    </div>

    <div class="footer-block">
      <p class="footer-heading">
        {% if lang == "zh" %}
        社群平台
        {% else %}
        Social
        {% endif %}
      </p>
      <p class="footer-links">
        {% include "components/social-links.njk" %}
      </p>
    </div>

    <div class="footer-block">
      <p class="footer-heading">
        {% if lang == "zh" %}
        聯絡方式
        {% else %}
        Contact
        {% endif %}
      </p>
      <p class="footer-contact-line">
        <i class="fa-solid fa-envelope fa-fw" aria-label="{% if lang == 'zh' %}電子郵件{% else %}Email{% endif %}"></i>
        <span data-secret="email"></span>
      </p>
      <p class="footer-contact-line">
        <i class="fa-solid fa-phone fa-fw" aria-label="{% if lang == 'zh' %}電話{% else %}Phone{% endif %}"></i>
        <span data-secret="phoneA"></span> / <span data-secret="phoneB"></span>
      </p>
    </div>
  </div>
</footer>
