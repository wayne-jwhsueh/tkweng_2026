{% macro tabs(years, currentYear, basePath, lang) %}
<div class="news-tabs" data-news-tabs role="tablist" aria-label="{{ 'Browse by year' if lang == 'en' else '依年份瀏覽' }}">
  {% for year in years %}
  <a href="{{ basePath }}{{ year }}/" class="news-tab{{ ' is-active' if year == currentYear }}" data-year="{{ year }}" role="tab" aria-selected="{{ 'true' if year == currentYear else 'false' }}">{{ year }}</a>
  {% endfor %}
</div>
{% endmacro %}

{% macro cards(posts, lang) %}
<ul class="list-clean news-list">
  {% for post in posts %}
  {% set thumb = post.data.cover | newsThumbUrl %}
  <li class="news-item">
    <article class="news-card{{ ' is-text-only' if not thumb }}">
      {% if thumb %}
      <a class="news-card-media" href="{{ post.url }}" aria-label="{{ 'Read' if lang == 'en' else '查看' }} {{ post.data.title }}">
        <img class="news-media" src="{{ thumb }}" alt="{{ post.data.coverAlt or post.data.title }}" width="560" height="315" loading="lazy" />
      </a>
      {% endif %}
      <div class="news-card-body">
        <div class="news-card-date">{{ post.date | date("yyyy-MM-dd") }}</div>
        <h3 class="news-card-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p class="news-card-summary">{{ post.data.summary | previewExcerpt(20) }}</p>
        <p class="news-card-link"><a href="{{ post.url }}">{{ 'Read more' if lang == 'en' else '閱讀內容' }}</a></p>
      </div>
    </article>
  </li>
  {% else %}
  <li class="news-item"><p class="meta">{{ 'No news for this year.' if lang == 'en' else '此年度尚無消息。' }}</p></li>
  {% endfor %}
</ul>
{% endmacro %}
