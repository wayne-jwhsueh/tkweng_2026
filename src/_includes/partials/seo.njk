{% set currentUrl = page.url or '/' %}
{% if lang == "zh" %}
{% set altLang = "en" %}
{% set altUrl = currentUrl | replace('/zh/', '/en/') %}
{% set ogLocale = "zh_TW" %}
{% set ogLocaleAlt = "en_US" %}
{% else %}
{% set altLang = "zh" %}
{% set altUrl = currentUrl | replace('/en/', '/zh/') %}
{% set ogLocale = "en_US" %}
{% set ogLocaleAlt = "zh_TW" %}
{% endif %}

{% set pageImage = image or cover or site.defaultImage %}
{% set pageDescription = description or site.descriptionEn %}
{% set pageOgType = ogType or "website" %}
{% set pageSiteName = site.siteNameZh if lang == "zh" else site.siteNameEn %}
{% set pageTitle = title + " | " + pageSiteName %}

<link rel="canonical" href="{{ site.url }}{{ currentUrl }}" />
<link rel="alternate" hreflang="en" href="{{ site.url }}{{ altUrl if lang == 'zh' else currentUrl }}" />
<link rel="alternate" hreflang="zh-Hant" href="{{ site.url }}{{ currentUrl if lang == 'zh' else altUrl }}" />
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ altUrl if lang == 'zh' else currentUrl }}" />

<meta property="og:site_name" content="{{ pageSiteName }}" />
<meta property="og:type" content="{{ pageOgType }}" />
<meta property="og:title" content="{{ pageTitle }}" />
<meta property="og:description" content="{{ pageDescription }}" />
<meta property="og:url" content="{{ site.url }}{{ currentUrl }}" />
<meta property="og:image" content="{{ site.url }}{{ pageImage }}" />
<meta property="og:locale" content="{{ ogLocale }}" />
<meta property="og:locale:alternate" content="{{ ogLocaleAlt }}" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ pageTitle }}" />
<meta name="twitter:description" content="{{ pageDescription }}" />
<meta name="twitter:image" content="{{ site.url }}{{ pageImage }}" />
