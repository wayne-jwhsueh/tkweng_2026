<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ site.siteNameEn }}</title>
    <meta name="robots" content="noindex" />
    <script>
      (function () {
        var saved = '';
        try { saved = localStorage.getItem('preferredLang') || ''; } catch(e) {}
        var lang = saved || navigator.language || navigator.userLanguage || '';
        window.location.replace(/^zh/i.test(lang) ? '/zh/' : '/en/');
      })();
    </script>
  </head>
  <body>
    <noscript>
      <p style="font-family:sans-serif;padding:2rem;">
        Please choose your language:
        <a href="/en/">English</a> &nbsp;|&nbsp; <a href="/zh/">繁體中文</a>
      </p>
    </noscript>
  </body>
</html>
