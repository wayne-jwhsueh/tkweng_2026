<!doctype html>
<html lang="{{ lang or 'en' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | {{ site.siteNameEn }}</title>
    <meta name="description" content="{{ description or site.descriptionEn }}" />
    {% include "partials/seo.njk" %}
    {% include "partials/structured-data.njk" %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=Noto+Sans+TC:wght@400;500;700&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/photoswipe.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {% include "components/header.njk" %}
    <main id="main-content" class="page-wrap">
      {{ content | safe }}
    </main>
    {% include "components/footer.njk" %}
    <script src="/assets/js/hero-random.js"></script>
    <script src="/assets/js/about-inspiration-parallax.js"></script>
    <script src="/assets/js/portfolio-thumb-random.js"></script>
    <script type="module" src="/assets/js/gallery-lightbox.js"></script>
    <script src="/assets/js/contact-obfuscate.js"></script>
    <script>try{localStorage.setItem('preferredLang','{{ lang or "en" }}');}catch(e){}</script>
  </body>
</html>
