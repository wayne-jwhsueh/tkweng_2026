---
layout: layouts/base.njk
title: News Archive
lang: zh
description: 依年份整理的歷年消息
permalink: "/zh/news/archive/index.html"
---

<h1>News Archive</h1>
<p class="meta">依年份瀏覽歷年消息。</p>

{% set years = collections.news_zh | newsYears %}

{% if years.length %}
<ul class="list-clean">
  {% for year in years %}
  <li><a href="#year-{{ year }}">{{ year }}</a></li>
  {% endfor %}
</ul>

{% for year in years %}
<h2 class="section-title" id="year-{{ year }}">{{ year }}</h2>
<ul class="list-clean news-list">
  {% for post in collections.news_zh | byYear(year) %}
  {% set thumb = post.data.cover | newsThumbUrl %}
  <li class="news-item">
    <article class="news-card{{ ' is-text-only' if not thumb }}">
      {% if thumb %}
      <a class="news-card-media" href="{{ post.url }}" aria-label="查看 {{ post.data.title }}">
        <img class="news-media" src="{{ thumb }}" alt="{{ post.data.coverAlt or post.data.title }}" width="560" height="315" loading="lazy" />
      </a>
      {% endif %}
      <div class="news-card-body">
        <div class="news-card-date">{{ post.date | date("yyyy-MM-dd") }}</div>
        <h3 class="news-card-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p class="news-card-summary">{{ post.data.summary | previewExcerpt(20) }}</p>
        <p class="news-card-link"><a href="{{ post.url }}">閱讀內容</a></p>
      </div>
    </article>
  </li>
  {% endfor %}
</ul>
{% endfor %}
{% else %}
<p class="meta">目前尚無彙整內容。</p>
{% endif %}

<p><a class="btn" href="/zh/news/">返回最新消息</a></p>
